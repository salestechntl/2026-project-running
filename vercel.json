{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/runs?expire_all=1",
      "schedule": "0 17 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/auth/me?health=1"
    },
    {
      "source": "/((?!api/|src/|@|node_modules/|assets/|favicon\\.svg|org-template\\.csv|coverPic\\.jpg).*)",
      "destination": "/index.html"
    }
  ]
}
