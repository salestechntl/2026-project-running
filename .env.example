# Supabase (จาก Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Vercel Environment Variables — อย่าใส่ VITE_ prefix)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Legacy JWT (eyJ...) or new secret key (sb_secret_...) — NOT publishable/anon
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_SECRET_KEY=sb_secret_...  # optional alias for SUPABASE_SERVICE_ROLE_KEY
JWT_SECRET=generate-with-openssl-rand-hex-32

# Auth mode: "api" | "local" (ไม่ใส่ = auto: api ถ้ามี VITE_SUPABASE_URL)
# VITE_AUTH_MODE=local

# Dev only — proxy /api ไป vercel dev (เมื่อรัน npm run dev แยกจาก vercel dev)
# VITE_API_PROXY=http://localhost:3000

# จำลองวันที่สำหรับทดสอบกฎบันทึก (yyyy-mm-dd) — ต้องตั้งทั้งสองตัวแล้ว redeploy
# VITE_SIMULATED_TODAY=2026-07-01
# SIMULATED_TODAY=2026-07-01

# Cron job หมดอายุรายการรออนุมัติ (Vercel Cron → GET /api/runs?expire_all=1)
# CRON_SECRET=generate-with-openssl-rand-hex-32
