# Supabase (จาก Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Vercel Environment Variables — อย่าใส่ VITE_ prefix)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=generate-with-openssl-rand-hex-32

# Auth mode: "api" | "local" (ไม่ใส่ = auto: api ถ้ามี VITE_SUPABASE_URL)
# VITE_AUTH_MODE=local

# Dev only — proxy /api ไป vercel dev (เมื่อรัน npm run dev แยกจาก vercel dev)
# VITE_API_PROXY=http://localhost:3000
